# Copy this file to .env and fill in the values.
#
# Generate a secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# Generate a strong DB password with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# Django
DJANGO_SECRET_KEY=change-me-generate-a-real-key
DJANGO_DEBUG=false
# Space-separated list of allowed hostnames, e.g.: un-project.org www.un-project.org
ALLOWED_HOSTS=your-domain.example.com

# Database
DB_NAME=unproject
DB_USER=unproject
DB_PASSWORD=change-me-generate-a-strong-password
DB_HOST=localhost
DB_PORT=5432

# Gunicorn (optional, defaults to 3)
# GUNICORN_WORKERS=4
